/** app.wxss */


page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #2a6885;
  
  --liu-red: #f13333;
  --liu-green: #39d739;
  --liu-blue: #2270f1;

  --primary-color: #2a6885;   /** 皇家蓝 #00416A */
  --on-primary: #fafafa;
  --primary-hover: #1c5671;
  --primary-active: #15455e;
  --inverse-primary: #88d1ff;

  --card-bg: #eaecef;
  --bg-color: #fff;

}

.liu-scroll-view {
  width: 100%;
  height: 100%;
  background-color: var(--bg-color);
}
