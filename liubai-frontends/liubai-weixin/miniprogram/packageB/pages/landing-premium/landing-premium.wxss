
@import "../../styles/custom-styles.wxss";

.lp-paid-container {
  min-height: 500px;
  height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.lp-paid-image {
  width: 120px;
  height: 120px;
  margin-top: 40px;
  margin-bottom: 60px;
}

.lp-paid-title {
  font-size: var(--head-font);
  font-weight: 700;
  color: var(--main-text);
  margin-bottom: 10px;
}

.lp-paid-tip {
  font-size: var(--desc-font);
  color: var(--main-text);
  margin-bottom: 60px;
  text-align: center;
  text-wrap: balance;
  width: 90%;
}

.lp-paid-btn {
  width: 50%;
  min-width: 160px;
  max-width: 240px;
  padding-bottom: 20px;
  position: relative;
}

.lp-container {
  min-height: 600px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.lp-emoji {
  margin-top: 90px;
  margin-bottom: 60px;
  font-size: 90px;
}

.lp-title {
  font-size: var(--head-font);
  font-weight: 700;
  color: var(--main-text);
  margin-bottom: 10px;
}

.lp-tip {
  font-size: var(--desc-font);
  color: var(--main-normal);
  margin-bottom: 60px;
  text-align: center;
  text-wrap: balance;
  width: 90%;
}

.lp-buy-btn {
  width: 100%;
  position: relative;
}

.lp-footer-box {
  margin-top: 20px;
  width: 90%;
  position: relative;
  padding-bottom: 50px;
}

.lp-hint {
  width: 100%;
  font-size: var(--mini-font);
  color: var(--main-note);
}

.lp-learn-more {
  font-size: var(--mini-font);
  color: var(--primary-color);
  transition: .15s;
}


