@import "../../styles/custom-styles.wxss";

.tdt-title {
  width: 100%;
  font-size: var(--desc-font);
  color: var(--main-normal);
  font-weight: 700;
  margin-bottom: 8px;
}

.tdt-picker {
  width: 100%;
  height: 170px;
  color: var(--main-normal);
  margin-bottom: 24px;
}

.tdt-picker-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tdt-bottom {
  width: 100%;
  height: 60px;
}