<view class="task-card" hover-class="liu-skyline-hover" catchtap="onTapCard">

  <view class="task-card-title">
    <text>{{task.desc}}</text>
  </view>

  <view wx:if="{{task.opengid}}" class="task-card-footer">
    <open-data type="groupName" open-gid="{{task.opengid}}" 
      default-text="来自群聊" binderror="onShowGroupNameErr"
    />
    <text wx:if="{{task.allDone}}">{{t1.all_done}}</text>
    <block wx:elif="{{task.doneCount}}">
      <text>{{t1.done_1}}{{task.doneCount}}{{t1.done_2}}</text>
    </block>

  </view>
  <view wx:elif="{{task.open_single_roomid}}" class="task-card-footer">

    <open-data-list wx:if="{{task.each_other_openid}}"
      members="{{[task.each_other_openid]}}"
      type="groupMembers"
    >
      <open-data-item type="userNickName" index="{{0}}" />
    </open-data-list>

    <text wx:else>{{t1.from_single_chat}}</text>
    <text wx:if="{{task.eachOtherDone}}">{{t1.each_other_done}}</text>
  </view>

</view>