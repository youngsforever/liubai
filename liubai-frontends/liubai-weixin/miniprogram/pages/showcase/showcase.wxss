/** showcase.wxss */

.showcase-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 500px;
}

.showcase-image-container {
  width: 90%;
  max-width: 450px;
  position: relative;
  margin-bottom: 30px;
}

.showcase-image-box {
  width: 100%;
  padding-bottom: 150%;
  box-sizing: border-box;
  position: relative;
  transition: .15s;
}

.showcase-image-box_hover {
  transform: scale(1.02);
}

.showcase-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.showcase-footer-box {
  width: 80%;
  max-width: 450px;
  font-size: var(--btn-font);
  color: var(--main-note);
  text-align: center;
  display: inline;
  text-wrap: balance;
}

.showcase-virtual {
  width: 100%;
  height: 50px;
}