/** index.wxss **/

.index-scroll-view {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 100%;
  min-height: 100vh;
}

.index-virtual-one {
  width: 100%;
  height: 25vh;
}

.index-logo-box {
  margin-bottom: 30px;
  width: 100px;
  height: 100px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.index-logo {
  width: 90%;
  height: 90%;
}

.index-title {
  font-size: var(--head-font);
  color: var(--main-text);
  font-weight: 700;
  margin-bottom: 6px;
  letter-spacing: 1px;
}

.index-desc {
  font-size: var(--desc-font);
  color: var(--main-text);
  margin-bottom: 20vh;
}

.index-btns {
  width: 90%;
  max-width: 400px;
  position: relative;
}


.index-btn {
  box-sizing: border-box;
  width: 100%;
  margin-bottom: 10px;
  border-radius: 30px;
  padding: 16px;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: var(--btn-font);
  font-weight: 700;
  background-color: var(--primary-color);
  color: var(--on-primary);
  cursor: pointer;
  transition: .15s;
}

.index-transparent-btn {
  background-color: transparent;
  color: var(--main-text);
}

@media (hover: hover) {
  .webview .index-btn:hover {
    background-color: var(--primary-hover);
  }

  .webview .index-transparent-btn:hover {
    background-color: transparent;
    opacity: .75;
  }
}

.webview .index-btn:active {
  background-color: var(--primary-active);
  transform: scale(0.98);
}

.webview .index-transparent-btn:active {
  background-color: transparent;
  opacity: .5;
}

.skyline .index-btn_hover {
  background-color: var(--primary-hover);
  transform: scale(0.98);
}

.skyline .index-transparent-btn_hover {
  background-color: transparent;
  opacity: .75;
}
