<!-- index.wxml -->
<scroll-view 
  class="liu-{{theme}} liu-scroll-view" 
  scroll-y 
  type="list"
>
  
  <view class="index-container {{renderer}}">

    <view class="index-virtual-one"></view>

    <!-- title -->
    <view class="index-title">
      <text>{{t1.title}}</text>
    </view>

    <!-- search box -->
    <view class="index-search-box">
      <input class="index-search-input" 
        placeholder-class="input-search-placeholder"
        placeholder="{{t1.placeholder}}" 
        cursor-spacing="20"
        always-embed
        maxlength="30"
        confirm-type="search"
        cursor-color="{{ theme === 'light' ? light_primary_color : dark_primary_color }}"
      />

      <view class="index-search-bar">
        <!-- search by image -->
        <view class="liu-hover index-image-box"
          hover-class="liu-skyline-hover"
        >
          <image src="{{imagePath}}photo.png" class="isb-image-icon" />
        </view>

        <!-- search button -->
        <view class="isb-footer">
          <index-search-button></index-search-button>
        </view>

      </view>
    </view>
   

    <view class="index-virtual-two"></view>
  </view>
</scroll-view>
